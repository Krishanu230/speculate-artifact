# ============================================================================
# Speculate LLM Configuration
# ============================================================================
# Copy this file to `reviewer.env` (or any name) and fill in only the
# provider(s) you plan to use. Pass it at runtime with:
#
#   docker run --env-file reviewer.env ...
#
# You only need ONE working provider. Leave the others as placeholders.
# The artifact should never ship real credentials.
#
# ============================================================================
# HOW MODEL RESOLUTION WORKS
# ============================================================================
# When you run the tool with --spec-model or --context-model, the name you
# pass (e.g., "o4_mini") is resolved as follows:
#
#   1. If the name contains "deepseek"  -> routes to DeepSeek provider
#   2. If the name matches an AZURE_MODEL_MAP_* key -> routes to Azure
#   3. If the name contains "gemini"    -> routes to Gemini provider
#   4. Otherwise                        -> routes to the default provider (Azure)
#
# If no --spec-model is given, AZURE_DEFAULT_MODEL_NAME is used.
#
# ============================================================================
# AZURE OPENAI
# ============================================================================
# Azure supports multiple configurations (endpoints). Each config has a
# unique name, an endpoint URL, and an API key.
#
# Step 1: List your config names (comma-separated if multiple)
AZURE_CONFIG_NAMES=primary
AZURE_DEFAULT_CONFIG_NAME=primary
AZURE_API_VERSION_FALLBACK=2024-05-01-preview

# Step 2: Define each config's endpoint and key
#   Variables follow the pattern: AZURE_ENDPOINT_<name>, AZURE_API_KEY_<name>
AZURE_ENDPOINT_primary=https://example.openai.azure.com/
AZURE_API_KEY_primary=CHANGE_ME
# AZURE_API_VERSION_primary=2024-05-01-preview   # optional per-config override

# Step 3: Map user-facing model names to config/deployment pairs
#   Format: AZURE_MODEL_MAP_<model_name>=<config_name>/<deployment_name>
#
#   <model_name> is what you pass to --spec-model (e.g., --spec-model o4_mini)
#   <config_name> must match a name from AZURE_CONFIG_NAMES
#   <deployment_name> is the Azure deployment name in that resource
#
#   Example: if you deployed "gpt-4.1-nano" as "my-nano" on the "primary"
#   resource, set: AZURE_MODEL_MAP_gpt_4_1_nano=primary/my-nano
AZURE_MODEL_MAP_gpt_4_1=primary/example-deployment
AZURE_MODEL_MAP_gpt_4_1_mini=primary/example-deployment
AZURE_MODEL_MAP_gpt_4_1_nano=primary/example-deployment
AZURE_MODEL_MAP_gpt_4o_mini=primary/example-deployment
AZURE_MODEL_MAP_gpt_5_nano=primary/example-deployment
AZURE_MODEL_MAP_gpt_o1=primary/example-deployment
AZURE_MODEL_MAP_o3_mini=primary/example-deployment
AZURE_MODEL_MAP_o4_mini=primary/example-deployment
AZURE_MODEL_MAP_deepseek_r1=primary/example-deployment

# Step 4: Set the default model (used when --spec-model is not specified)
AZURE_DEFAULT_MODEL_NAME=gpt_4_1_nano

# --- Adding a second Azure config ---
# To use deployments across multiple Azure resources:
#
#   AZURE_CONFIG_NAMES=primary,secondary
#   AZURE_ENDPOINT_secondary=https://other-resource.openai.azure.com/
#   AZURE_API_KEY_secondary=your-other-key
#   AZURE_MODEL_MAP_gpt_4_1=secondary/my-gpt41-deployment
#
# The tool picks the right endpoint automatically based on the model map.

# ============================================================================
# VERTEX AI (GEMINI)
# ============================================================================
GOOGLE_VERTEX_PROJECT_ID=your-gcp-project-id
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_API_KEY=CHANGE_ME

# ============================================================================
# DEEPSEEK
# ============================================================================
DEEPSEEK_ENDPOINT=https://api.deepseek.com
DEEPSEEK_API_KEY=CHANGE_ME
DEEPSEEK_MODEL_NAME=DeepSeek-R1-0528
