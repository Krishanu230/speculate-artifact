FROM ubuntu:22.04

# Prevent interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# 1. Install prerequisites and Add PostgreSQL repo
RUN apt-get update && apt-get install -y \
    software-properties-common curl gnupg \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc | gpg --dearmor -o /etc/apt/keyrings/postgresql.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/postgresql.gpg] http://apt.postgresql.org/pub/repos/apt jammy-pgdg main" > /etc/apt/sources.list.d/pgdg.list

# 2. Install System Dependencies
RUN apt-get update && apt-get install -y \
    postgresql-client-15 nodejs npm dos2unix gcc default-libmysqlclient-dev \
    ffmpeg exiftool libmagic1 libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# 3. Install Python 3.9 via Deadsnakes
RUN add-apt-repository -y ppa:deadsnakes/ppa && \
    apt-get update && apt-get install -y \
    python3.9 python3.9-venv python3.9-dev \
    && rm -rf /var/lib/apt/lists/*

# 4. Create Virtual Environments
RUN python3.9 -m venv /venvs/treeherder && \
    python3.9 -m venv /venvs/mathesar && \
    python3.9 -m venv /venvs/librephotos

# --- 5. SETUP TREEHERDER ---
WORKDIR /artifact/repos/treeherder
COPY repos/treeherder .
# Install Treeherder's requirements using ITS specific venv
RUN /venvs/treeherder/bin/pip install --no-cache-dir -r requirements/common.txt
# Install Speculate Tool dependencies into the Treeherder venv
RUN /venvs/treeherder/bin/pip install --no-cache-dir httpcore httpx mixpanel openai python-dotenv aiofiles google-generativeai colorama azure-ai-inference

# --- 6. SETUP MATHESAR ---
WORKDIR /artifact/repos/mathesar
COPY repos/mathesar .
# Fix line endings just like we did in the original Mathesar setup
RUN find . -type f -name "*.sh" -exec sed -i 's/\r$//' {} +
# Install Mathesar's requirements using ITS specific venv
RUN /venvs/mathesar/bin/pip install --no-cache-dir -r requirements.txt
# Apply the pandas/numpy fix you documented
RUN /venvs/mathesar/bin/pip install --upgrade --force-reinstall numpy pandas
# Install Speculate Tool dependencies into the Mathesar venv
RUN /venvs/mathesar/bin/pip install --no-cache-dir httpcore httpx mixpanel openai python-dotenv aiofiles google-generativeai colorama azure-ai-inference

# --- 6.5 UPGRADE PYTHON FOR LIBREPHOTOS & EDUCATION BACKEND ---
# Matplotlib 3.10.1 requires Python 3.10+. We install 3.11.
RUN apt-get update && apt-get install -y \
    python3.11 python3.11-venv python3.11-dev cmake g++ \
    && rm -rf /var/lib/apt/lists/*    

# Overwrite the old 3.9 librephotos venv with a fresh 3.11 venv
RUN python3.11 -m venv --clear /venvs/librephotos

# --- 7. SETUP LIBREPHOTOS ---
WORKDIR /artifact/repos/librephotos
COPY repos/librephotos .
# Install the repo's requirements into the new 3.11 venv (with extended timeout)
RUN /venvs/librephotos/bin/pip install --default-timeout=1000 --no-cache-dir -r requirements.txt
# Install Speculate Tool dependencies into the same venv
RUN /venvs/librephotos/bin/pip install --default-timeout=1000 --no-cache-dir httpcore httpx mixpanel openai python-dotenv aiofiles google-generativeai PyYAML colorama azure-ai-inference

# ==========================================
# --- 8. EDUCATION BACKEND (Python 3.11) ---
# ==========================================
# 1. Install specific system dependencies needed by Edu Backend
RUN apt-get update && apt-get install -y gettext tzdata && rm -rf /var/lib/apt/lists/*

# 2. Create a fresh isolated environment
RUN python3.11 -m venv --clear /venvs/edubackend
WORKDIR /artifact/repos/education-backend
COPY repos/education-backend .

# 3. Fix Windows line endings and initialize the environment variables
RUN dos2unix src/manage.py && cp src/core/.env.ci src/core/.env

# 4. Install poetry AND the export plugin, dynamically generate requirements, and install
RUN /venvs/edubackend/bin/pip install --no-cache-dir poetry poetry-plugin-export && \
    /venvs/edubackend/bin/poetry export --format=requirements.txt > generated_requirements.txt && \
    /venvs/edubackend/bin/pip install --default-timeout=1000 --no-cache-dir -r generated_requirements.txt    

# 5. Install the specific apidocs tool dependencies for this venv
RUN /venvs/edubackend/bin/pip install --no-cache-dir httpcore httpx mixpanel openai python-dotenv aiofiles google-generativeai PyYAML colorama azure-ai-inference

WORKDIR /artifact
ENTRYPOINT []
CMD ["/bin/bash"]